{
	"name": "hono-learn-ejs2",
	"type": "module",
	"scripts": {
		"preinstall": "pnpm audit",
		"dev": "tsx watch src/index.ts",
		"stop": "pkill -f 'watch src/index.ts'",
		"check:server": "node scripts/check-server.mjs",
		"build": "tsc",
		"start": "node dist/index.js",
		"format": "oxfmt",
		"lint": "oxlint",
		"check": "oxfmt && oxlint --fix",
		"playwright:install:browser:original": "playwright install chromium",
		"playwright:install:browser": "node scripts/download_chromes.mjs",
		"playwright:list:browser": "playwright install --list",
		"playwright:install:test": "playwright cr 127.0.0.1:3000",
		"codegen": "playwright codegen",
		"test:e2e": "playwright test",
		"inc1": "tsx scripts/increment-and-screenshot.ts",
		"inc2": "tsx scripts/increment2-and-screenshot.ts"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.14",
		"ejs": "^5.0.2",
		"hono": "^4.12.14"
	},
	"devDependencies": {
		"@playwright/cli": "^0.1.8",
		"@playwright/mcp": "^0.0.70",
		"@playwright/test": "^1.59.1",
		"@types/ejs": "^3.1.5",
		"@types/node": "^25.6.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	}
}

{
	"name": "hono-learn-ejs2",
	"type": "module",
	"scripts": {
		"preinstall": "pnpm audit",
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"format": "biome format --write .",
		"format:all": "biome format --write . && dprint fmt",
		"playwright:install": "playwright install chromium",
		"playwright:install:test": "playwright cr 127.0.0.1:3000",
		"codegen": "playwright codegen",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.9",
		"ejs": "^4.0.1",
		"hono": "^4.12.4"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@types/ejs": "^3.1.5",
		"@types/node": "^20.19.35",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
